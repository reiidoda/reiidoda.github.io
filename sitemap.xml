---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign html_pages = site.html_pages | sort: 'url' %}
{% for node in html_pages %}
  {% assign include_in_sitemap = true %}
  {% if node.sitemap == false %}
    {% assign include_in_sitemap = false %}
  {% endif %}
  {% if node.url == '/404.html' %}
    {% assign include_in_sitemap = false %}
  {% endif %}
  {% if include_in_sitemap %}
  <url>
    <loc>{{ node.url | replace: 'index.html', '' | absolute_url }}</loc>
    {% if node.date %}
    <lastmod>{{ node.date | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
  {% endif %}
{% endfor %}
{% assign sorted_posts = site.posts | sort: 'date' | reverse %}
{% for post in sorted_posts %}
  <url>
    <loc>{{ post.url | replace: 'index.html', '' | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
  </url>
{% endfor %}
</urlset>
